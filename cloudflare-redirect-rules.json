[
  {
    "description": "Root to default locale",
    "expression": "(http.request.uri.path eq \"/\")",
    "status_code": 301,
    "target_url": "https://cyblight.org/ru/"
  },
  {
    "description": "Legacy /games to /ru/games/",
    "expression": "(http.request.uri.path eq \"/games\" or http.request.uri.path eq \"/games/\")",
